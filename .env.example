# Copy this file to .env and fill in the values
# cp .env.example .env

# Auth secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Database (SQLite by default, no config needed)
# For Postgres: DATABASE_URL=postgres://user:pass@localhost:5432/tecton

# OAuth (optional — leave blank to use credentials-only auth)
# Google: https://console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers -> OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email verification policy
# Set VERIFY_EMAIL=false to skip email verification (convenient for local dev)
# Default: true (production-safe — new users must verify before first login)
# VERIFY_EMAIL=false
